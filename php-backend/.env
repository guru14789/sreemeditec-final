# App Configuration
APP_ENV=development
APP_MODE=demo
APP_DEBUG=true
APP_URL=http://localhost:5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=sreemeditec_db

# JWT Configuration
JWT_SECRET=development-jwt-secret-key-change-in-production-for-security
JWT_EXPIRATION=86400

# Payment Configuration (Demo Mode)
RAZORPAY_KEY_ID=demo_key_id
RAZORPAY_KEY_SECRET=demo_key_secret
RAZORPAY_WEBHOOK_SECRET=demo_webhook_secret

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp,pdf

# Email Configuration (Optional for demo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=demo@example.com
SMTP_PASSWORD=demo_password
SMTP_ENCRYPTION=tls

# DTDC Courier Configuration (Demo Mode)
DTDC_API_KEY=demo_dtdc_key
DTDC_API_SECRET=demo_dtdc_secret
DTDC_BASE_URL=https://api.dtdc.in/v1
